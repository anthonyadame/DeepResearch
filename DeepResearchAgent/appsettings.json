{
  "LlmProvider": {
    "Provider": "ollama",
    "RequestTimeoutSeconds": 120,
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "DefaultModel": "gpt-oss:20b"
    },
    "LiteLLM": {
      "BaseUrl": "http://127.0.0.1:4000",
      "DefaultModel": "qwen3.5-4b",
      "ApiKey": "sk-1234"
    }
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "DefaultModel": "gpt-oss:20b"
  },
  "SearXNG": {
    "BaseUrl": "http://localhost:8080"
  },
  "Crawl4AI": {
    "BaseUrl": "http://localhost:11235",
    // Profile name to use for authenticated crawling
    // Must exist in ProfilesPath directory (created in WSL2)
    // Example: if Profile is "default", Docker looks for /home/crawl4ai/profiles/default/
    "Profile": "default",
    "Headless": true,
    "MaxCrawlDepth": 2,
    "MaxPages": 5,
    "RequestTimeoutSeconds": 30,
    // DelayBetweenRequestsMs set to 3000 milliseconds (3 seconds) to be polite to servers and look human-like
    "DelayBetweenRequestsMs": 3000,
    // Path inside Docker container where profiles are mounted
    // IMPORTANT: This MUST match the docker-compose.yml volume mount path
    // docker-compose.yml: C:\Users\<YourUser>\crawl4ai_profiles:/home/crawl4ai/profiles
    // So ProfilesPath should be: /home/crawl4ai/profiles
    // Folder is mounted via Docker volume, not created in container
    // If folder doesn't exist on Windows, Docker will fail to mount it
    "ProfilesPath": "/home/appuser/crawl4ai/profiles"
  },
  "Lightning": {
    "ServerUrl": "http://localhost:8090",
    "RMPT": {
      "enabled": true,
      "optimizationStrategy": "Balanced"
    }
  },
  "IterativeClarification": {
    "MaxIterations": 5,//3,
    "QualityThreshold": 75.0,
    "EnableCritique": true,
    "EnableQualityMetrics": true,
    "MaxTimeoutSeconds": 60,
    "UseIterativeAgent": false,
    "StoreIterationHistory": true,
    "MinCritiqueConfidence": 0.6
  },
  //"WorkflowModelConfiguration": {
  //  "SupervisorBrainModel": "gpt-oss:20b",
  //  "SupervisorToolsModel": "mistral:7b",
  //  "QualityEvaluatorModel": "mistral:7b",
  //  "RedTeamModel": "gpt-oss:20b",
  //  "ContextPrunerModel": "mistral:7b"
  //},
  "OpenTelemetry": {
    "ServiceName": "DeepResearchAgent",
    "ServiceVersion": "0.6.5",
    "Environment": "development",
    "Exporters": {
      "Otlp": {
        "Endpoint": "http://localhost:4317",
        "Protocol": "grpc"
      },
      "Prometheus": {
        "ScrapeEndpointPath": "/metrics",
        "Enabled": true
      },
      "Console": {
        "Enabled": false
      }
    },
    "Tracing": {
      "Enabled": true,
      "Sampler": "AlwaysOn",
      "ActivitySourceName": "DeepResearchAgent"
    },
    "Metrics": {
      "Enabled": true,
      "ExportIntervalMilliseconds": 5000
    },
    "Logging": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true
    }
  },
  "WorkflowModelConfiguration": {
    "SupervisorBrainModel": "gpt-oss:20b",
    "SupervisorToolsModel": "qwen3.5:0.8b",
    "QualityEvaluatorModel": "qwen3.5:0.8b",
    "RedTeamModel": "gpt-oss:20b",
    "ContextPrunerModel": "qwen3.5:0.8b"
  }

}

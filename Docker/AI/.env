# ═══════════════════════════════════════════════════════════════════════════════
# AI STACK ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Configuration for Ollama, Qdrant, and Lightning-Server services

# ─────────────────────────────────────────────────────────────────────────────
# Ollama Configuration
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODELS=/root/.ollama/models

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant Configuration
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Lightning Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
LIGHTNING_PORT=8090
APO_ENABLED=true
VERL_ENABLED=true
APO_STRATEGY=balanced
APO_MAX_TASKS=10
APO_TASK_TIMEOUT=300
VERL_TRACKING_ENABLED=true
VERL_CONFIDENCE_THRESHOLD=0.7

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# AI STACK ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Configuration for Ollama, Qdrant, and Lightning-Server services

# ─────────────────────────────────────────────────────────────────────────────
# Ollama Configuration
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODELS=/root/.ollama/models

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant Configuration
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Lightning Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
LIGHTNING_PORT=8090
RMPT_ENABLED=true
RLCS_ENABLED=true
RMPT_STRATEGY=balanced
RMPT_MAX_TASKS=10
RMPT_TASK_TIMEOUT=300
RLCS_TRACKING_ENABLED=true
RLCS_CONFIDENCE_THRESHOLD=0.7

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

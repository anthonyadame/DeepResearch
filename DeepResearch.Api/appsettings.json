{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DeepResearchAgent": "Information",
      "DeepResearch.Api": "Information"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": true
  },
  "HttpsRedirection": {
    "Enabled": false
  },
  "Observability": {
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableDetailedTracing": true,
    "TraceSamplingRate": 1.0,
    "SlowOperationThresholdMs": 0,
    "UseAsyncMetrics": false,
    "AsyncMetricsQueueSize": 10000,
    "EnableActivityEvents": true,
    "EnableExceptionRecording": true
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317",
    "PrometheusPort": "9464"
  },
  "Jwt": {
    "SecretKey": "", // Override via environment variable or user secrets
    "Issuer": "deepresearch-api",
    "Audience": "deepresearch-api",
    "ExpirationMinutes": 60
  },
  "Lightning": {
    "ServerUrl": "http://localhost:8090"
  },
  "LightningStore": {
    "DataDirectory": "data",
    "FileName": "lightningstore.json",
    "UseLightningServer": false,
    "ResourceNamespace": "facts"
  },
  "DataProtection": {
    "KeysDirectory": "data/keys"
  },
  "Checkpointing": {
    "EnableAutoCheckpoints": true,
    "AutoCheckpointInterval": "00:05:00",
    "CheckpointAfterEachAgent": true,
    "MaxCheckpointsPerWorkflow": 10,
    "MaxCheckpointSizeBytes": 52428800,
    "StorageBackend": "file",
    "LocalStorageDirectory": "data/checkpoints"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "DefaultModel": "llama3.1:8b"
  },
  "Search": {
    "SearXNG": {
      "BaseUrl": "http://localhost:8080"
    },
    "Crawl4AI": {
      "BaseUrl": "http://localhost:8000"
    }
  },
  "VectorDatabase": {
    "Enabled": false,
    "Embedding": {
      "ApiUrl": "http://localhost:11434",
      "Model": "nomic-embed-text"
    },
    "Qdrant": {
      "BaseUrl": "http://localhost:6333",
      "ApiKey": "",
      "CollectionName": "research_documents",
      "VectorDimension": 768,
      "TimeoutMs": 30000
    }
  },
  "ExperimentMetrics": {
    "DataDirectory": "data/experiments",
    "FileName": "metrics.jsonl"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5000"
      }
    }
  }
}

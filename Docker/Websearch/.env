# ═══════════════════════════════════════════════════════════════════════════════
# WEBSEARCH STACK ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Configuration for SearXNG, Crawl4AI, and Caddy services

# ─────────────────────────────────────────────────────────────────────────────
# Caddy Configuration
# ─────────────────────────────────────────────────────────────────────────────
SEARXNG_HOSTNAME=localhost
LETSENCRYPT_EMAIL=admin@example.com
CADDY_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# SearXNG Configuration
# ─────────────────────────────────────────────────────────────────────────────
SEARXNG_BASE_URL=https://localhost/
SEARXNG_SECRET_KEY=your-secret-key-change-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Crawl4AI Configuration
# ─────────────────────────────────────────────────────────────────────────────
CRAWL4AI_PROFILES_PATH=./Docker/Websearch/crawl4ai_profiles
CRAWL4AI_LOG_LEVEL=INFO
CRAWL4AI_API_PORT=11235

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Environment Variables for DeepResearch Stack
# Copy this to .env and customize for your deployment

# ═══════════════════════════════════════════════════════════
# MongoDB Configuration
# ═══════════════════════════════════════════════════════════
# Default password for MongoDB
# IMPORTANT: Change this in production!
MONGO_PASSWORD=lightningpass

# ═══════════════════════════════════════════════════════════
# OpenTelemetry Configuration
# ═══════════════════════════════════════════════════════════
# OTEL collector endpoint (default: deepresearch-otel-collector:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://deepresearch-otel-collector:4317

# Trace sampling rate (0.0 to 1.0)
# 0.1 = 10% of traces, 1.0 = all traces
# OTEL_TRACES_SAMPLER_ARG=0.1

# ═══════════════════════════════════════════════════════════
# Lightning Server Configuration
# ═══════════════════════════════════════════════════════════
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, staging, production
# ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════
# LiteLLM Configuration (if using vLLM stack)
# ═══════════════════════════════════════════════════════════
# Master API key for LiteLLM
# IMPORTANT: Change this in production!
# LITELLM_MASTER_KEY=sk-1234

# ═══════════════════════════════════════════════════════════
# InfluxDB Configuration (if using monitoring stack)
# ═══════════════════════════════════════════════════════════
# INFLUXDB_USERNAME=admin
# INFLUXDB_PASSWORD=password
# INFLUXDB_ORG=deep-research
# INFLUXDB_BUCKET=research
# INFLUXDB_TOKEN=influx-token

# ═══════════════════════════════════════════════════════════
# Qdrant Configuration (if using AI stack)
# ═══════════════════════════════════════════════════════════
# QDRANT_API_KEY=

# ═══════════════════════════════════════════════════════════
# External API Keys (optional)
# ═══════════════════════════════════════════════════════════
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

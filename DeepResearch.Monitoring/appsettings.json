{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OpenTelemetry": "Information"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "DeepResearchMonitoring",
    "ServiceVersion": "1.0.0",
    "Environment": "development",
    "Exporters": {
      "Otlp": {
        "Endpoint": "http://localhost:4317",
        "Protocol": "grpc"
      },
      "Prometheus": {
        "ScrapeEndpointPath": "/metrics",
        "ScrapeResponseCacheDurationMilliseconds": 300
      }
    },
    "Tracing": {
      "Enabled": true,
      "Sampler": "AlwaysOn"
    },
    "Metrics": {
      "Enabled": true,
      "PeriodicExportingMetricReaderOptions": {
        "ExportIntervalMilliseconds": 5000,
        "ExportTimeoutMilliseconds": 30000
      }
    }
  },
  "Prometheus": {
    "Port": 9090,
    "ScrapeInterval": "5s"
  },
  "Jaeger": {
    "AgentHost": "localhost",
    "AgentPort": 6831,
    "CollectorEndpoint": "http://localhost:14268/api/traces"
  },
  "Grafana": {
    "Url": "http://localhost:3000",
    "DefaultDashboards": true
  }
}

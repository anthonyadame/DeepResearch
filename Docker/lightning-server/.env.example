# Lightning Server Environment Configuration
# Copy this file to .env and update with your actual values

# ========== Server Configuration ==========
LIGHTNING_PORT=9090
PROMETHEUS_PORT=9091
LOG_LEVEL=INFO

# ========== MongoDB Configuration ==========
# MongoDB connection URI (replica set required)
MONGO_URI=mongodb://mongo1:27017,mongo2:27018,mongo3:27019/?replicaSet=rs0
MONGO_DATABASE=agentlightning
MONGO_PARTITION_ID=lightning-server-1

# MongoDB connection pool settings
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_CONNECT_TIMEOUT=30000
MONGO_SERVER_SELECTION_TIMEOUT=30000

# ========== vLLM Configuration ==========
# Primary LLM serving engine
VLLM_API_BASE=http://vllm-server:8000/v1
VLLM_MODEL_NAME=llama-3.1-8b
VLLM_API_KEY=EMPTY

# vLLM Model Selection (choose one):
# - meta-llama/Llama-3.1-8B-Instruct (default, 8B, 16GB GPU, 8K context)
# - mistralai/Mistral-7B-Instruct-v0.3 (7B, 14GB GPU, 32K context, fast)
# - Qwen/Qwen2.5-7B-Instruct (7B, 14GB GPU, 32K-128K context, multilingual)
# - Qwen/Qwen3.5-9B (9B, 18GB GPU, 32K context, latest Qwen, improved reasoning)
# - openai/gpt-oss-20b (20B, 40GB GPU, 8K context, general purpose/research)
# - deepseek-ai/deepseek-coder-33b-instruct (33B, 70GB GPU, 16K context, code specialist)
# - meta-llama/Llama-3.1-70B-Instruct (70B, 140GB GPU 2xA100, 8K context, best quality)

# vLLM performance tuning
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=8192  # Mistral/Qwen: 32768, DeepSeek: 16384
VLLM_MAX_NUM_SEQS=256  # Reduce for larger models or longer contexts
VLLM_TENSOR_PARALLEL_SIZE=1  # Use 2+ for 33B+ models
VLLM_TRUST_REMOTE_CODE=true  # Required for Mistral, Qwen, DeepSeek
VLLM_ENABLE_PREFIX_CACHING=true  # Enable KV cache sharing

# Qwen-specific: Extended context with RoPE scaling
# VLLM_ROPE_SCALING={"type":"dynamic","factor":4.0}  # For 128K context

# ========== LLM Proxy Configuration ==========
LLMPROXY_HOST=0.0.0.0
LLMPROXY_PORT=8080

# LiteLLM routing strategy
LITELLM_ROUTING_STRATEGY=usage-based-routing
LITELLM_ALLOWED_FAILS=3
LITELLM_COOLDOWN_TIME=60

# ========== External LLM APIs (Optional) ==========
# OpenAI (for APO gradient computation or fallback)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ========== Ollama Configuration (Optional) ==========
# Uncomment to enable Ollama as alternative backend
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ========== VERL Configuration ==========
# VERL training settings
VERL_ENABLED=true
VERL_TRAIN_BATCH_SIZE=32
VERL_MAX_PROMPT_LENGTH=4096
VERL_MAX_RESPONSE_LENGTH=2048
VERL_N_ROLLOUTS=4
VERL_PPO_LEARNING_RATE=1e-6
VERL_N_GPUS_PER_NODE=1

# VERL model configuration
VERL_MODEL_PATH=meta-llama/Llama-3.1-8B-Instruct
VERL_TENSOR_PARALLEL_SIZE=1

# ========== APO Configuration ==========
# APO prompt optimization settings
APO_ENABLED=true
APO_GRADIENT_MODEL=gpt-4o-mini
APO_APPLY_EDIT_MODEL=gpt-4o-mini
APO_BEAM_WIDTH=4
APO_BRANCH_FACTOR=4
APO_BEAM_ROUNDS=3
APO_GRADIENT_BATCH_SIZE=4
APO_VAL_BATCH_SIZE=16
APO_DIVERSITY_TEMPERATURE=1.0

# ========== OpenTelemetry Configuration ==========
# OTLP traces endpoint (auto-configured by LightningStoreServer)
# OTLP_TRACES_ENDPOINT=http://lightning-server:9090/v1/traces

# External OTLP collector (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Trace sampling
OTEL_TRACE_SAMPLING_RATE=1.0

# ========== Metrics & Monitoring ==========
# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=true

# WandB logging (optional)
# WANDB_API_KEY=your-wandb-api-key
# WANDB_PROJECT=DeepResearch
# WANDB_ENTITY=your-wandb-entity

# ========== Monitoring & Telemetry ==========
# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=true

# OpenTelemetry configuration
OTEL_ENABLED=true
OTEL_OTLP_ENDPOINT=http://lightning-server:9090/v1/traces
OTEL_EXPORT_TIMEOUT=30
OTEL_CONSOLE_EXPORT=false
OTEL_SERVICE_NAME=lightning-server

# Environment label for metrics/traces
ENVIRONMENT=development

# ========== Security ==========
# API authentication (optional)
# API_KEY=your-secure-api-key-here

# CORS settings
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# ========== RMPT & RLCS (Legacy, for backward compatibility) ==========
RMPT_ENABLED=true
RMPT_STRATEGY=balanced
RMPT_MAX_TASKS=10

RLCS_ENABLED=true
RLCS_CONFIDENCE_THRESHOLD=0.7

# ========== Performance Tuning ==========
# Worker settings
MAX_WORKERS=4
WORKER_TIMEOUT=600

# Rollout configuration
ROLLOUT_TIMEOUT_SECONDS=600
ROLLOUT_UNRESPONSIVE_SECONDS=120
ROLLOUT_MAX_ATTEMPTS=3

# ========== Development & Debugging ==========
# Set to true for development mode
DEBUG=false

# Enable detailed logging
VERBOSE_LOGGING=false

# Disable healthcheck during development
# DISABLE_HEALTHCHECK=true

# ========== Docker-Specific Settings ==========
# CUDA settings (for GPU containers)
CUDA_VISIBLE_DEVICES=0

# Container resource limits (for docker-compose)
CONTAINER_MEMORY_LIMIT=16g
CONTAINER_CPU_LIMIT=4
